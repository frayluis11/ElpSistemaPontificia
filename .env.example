# Configuración de variables de entorno para Sistema ELP
# Archivo .env para desarrollo - NO COMMITEAR CON VALORES REALES

# Base de datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres_secure_2024!
DB_NAME=sistemaelp_db

# Configuración JWT y seguridad
SECRET_KEY=your-super-secret-key-change-in-production-2024!
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Configuración del servidor
SERVER_HOST=127.0.0.1
SERVER_PORT=8000
DEBUG=True

# Configuración de archivos
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# Configuración de logs
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Frontend URL para CORS
FRONTEND_URL=http://localhost:3000

# Configuración SMTP (opcional para notificaciones)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=sistema@pontificia.edu.co